# Copy to .env on the VPS and fill in real values. NEVER commit the real .env.
#   cp .env.example .env && nano .env

# The domain/subdomain that points (DNS A record) at your VPS public IP.
# Caddy gets the HTTPS cert for exactly this name.
API_DOMAIN=api.tenkasifresh.in

# MySQL (runs in a container on the VPS).
MYSQL_DATABASE=FruitmarketDb
MYSQL_ROOT_PASSWORD=change-me-to-a-strong-db-password

# JWT signing key — must be long & random (>= 32 bytes). Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-production-secret

# Seed admin account created on first boot.
SEED_ADMIN_EMAIL=admin@tenkasifresh.in
SEED_ADMIN_PASSWORD=change-me-strong-admin-password

# ── Email (password-reset & transactional mail) ──────────────────────────────
# Set EMAIL_ENABLED=true once the mailbox credentials below are filled in.
# Hostinger mailbox: host smtp.hostinger.com, port 465 (SSL) or 587 (STARTTLS).
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.hostinger.com
EMAIL_SMTP_PORT=465
EMAIL_USE_SSL=true
EMAIL_USERNAME=noreply@tenkasifresh.in
EMAIL_PASSWORD=change-me-mailbox-password
EMAIL_FROM_ADDRESS=noreply@tenkasifresh.in
EMAIL_FROM_NAME=Tenkasi Fresh
# Storefront base URL used to build the reset-password link in emails.
EMAIL_FRONTEND_URL=https://tenkasifresh.in
