#!/usr/bin/env bash
# Production launcher for the Fruitmarket API on the VPS.
#
# Secrets are injected as environment variables here instead of being committed to
# appsettings.json. Env vars override appsettings.json, so this also survives every
# WinSCP re-upload of the published folder.
#
# Setup (once, on the VPS):
#   1. Copy this file next to the published Fruitmarket.API.dll and name it run.sh
#        cp run.sh.example run.sh
#   2. Fill in the real values below (replace every __PLACEHOLDER__).
#   3. chmod +x run.sh
#   4. Start the API with:  ./run.sh
#
# run.sh is gitignored — NEVER commit the filled-in version.
set -euo pipefail
cd "$(dirname "$0")"

export ASPNETCORE_ENVIRONMENT=Production

# MySQL runs locally on the VPS — connect over loopback.
export ConnectionStrings__DefaultConnection="Server=127.0.0.1;Port=3306;Database=FruitmarketDb;User=apiuser;Password=__DB_PASSWORD__;"

# JWT signing key. Must be long & random (>= 32 bytes). Generate with: openssl rand -base64 48
export Jwt__Secret="__JWT_SECRET__"

# Seed admin — only used on first boot when no Admin user exists yet.
# PhoneNumber is the login identifier (login is phone-based). 10 digits, no +91.
export SeedAdmin__Email="__ADMIN_EMAIL__"
export SeedAdmin__Password="__ADMIN_PASSWORD__"
export SeedAdmin__PhoneNumber="__ADMIN_PHONE__"

# Hostinger SMTP mailbox password (for transactional email).
export Email__Password="__SMTP_PASSWORD__"

# ── SMS gateway (OTP password reset) ─────────────────────────────────────────
# Flip Sms__Enabled to true once ApiKey is filled in; while false the OTP is only
# written to the app log (no SMS sent), so real users can't complete a reset.
export Sms__Enabled=false
export Sms__Provider="Fast2SMS"              # or "MSG91"
export Sms__ApiKey="__SMS_API_KEY__"
export Sms__SenderId="__SMS_SENDER_ID__"     # MSG91 (DLT sender) — leave blank for Fast2SMS
export Sms__TemplateId="__SMS_TEMPLATE_ID__" # MSG91 (DLT template) — leave blank for Fast2SMS

# Cashfree online payments. Use "sandbox" while testing, "production" to go live.
# App ID + Secret Key come from the Cashfree dashboard (Developers → API Keys).
export Cashfree__Enabled=true
export Cashfree__Environment="production"
export Cashfree__AppId="__CASHFREE_APP_ID__"
export Cashfree__SecretKey="__CASHFREE_SECRET_KEY__"
export Cashfree__ReturnUrl="https://tenkasifresh.in/orders"

exec dotnet ./Fruitmarket.API.dll
